# Relay API - Environment Configuration
# Copy this file to .env and update values for your environment

# ===== APPLICATION CONFIG =====
APP_ENV=development              # development, staging, production
DEBUG=true                       # Enable debug logging

# ===== SERVER CONFIG =====
SERVER_HOST=localhost            # Server hostname
SERVER_PORT=8080                 # Server port
SERVER_TIMEOUT=30                # Request timeout in seconds
SERVER_MAX_BODY_SIZE=1048576     # Max request body size in bytes (1MB)

# ===== DATABASE CONFIG =====
DB_HOST=localhost                # PostgreSQL host
DB_PORT=5432                     # PostgreSQL port
DB_USER=postgres                 # Database user
DB_PASSWORD=postgres             # Database password (change in production!)
DB_NAME=relay                    # Database name
DB_SSL_MODE=disable              # disable, allow, prefer, require
DB_MAX_CONN=25                   # Maximum connection pool size

# ===== REDIS CONFIG =====
REDIS_HOST=localhost             # Redis host
REDIS_PORT=6379                  # Redis port
REDIS_PASSWORD=                  # Redis password (empty if none)
REDIS_DB=0                       # Redis database number (0-15)

# ===== NOTES =====
# - For local development, copy this file to .env and keep defaults
# - For production, use a secure secrets manager (Azure Key Vault, AWS Secrets Manager, etc.)
# - Database passwords should NEVER be committed to version control
# - Use strong, random passwords in production
